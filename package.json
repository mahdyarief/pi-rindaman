{
  "name": "rindaman",
  "version": "1.0.0",
  "description": "OpenCode plugin and Pi package for strict response discipline, lifecycle verification, and quality checks.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "rindaman": "bin/rindaman.cjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "bin",
    "dist",
    "extensions",
    "skills",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SKILL.md",
    "src/quality-engine",
    "opencode.example.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "node bin/rindaman.cjs",
    "doctor": "node bin/rindaman.cjs doctor",
    "release:check": "npm run typecheck && npm run build && npm test && node bin/rindaman.cjs doctor --json && npm pack --dry-run",
    "release:pack": "npm pack",
    "test": "node --test"
  },
  "keywords": [
    "opencode",
    "plugin",
    "pi-package",
    "pi-skill",
    "quality",
    "code-quality",
    "typescript",
    "biome",
    "knip"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mahdyarief/rindaman.git"
  },
  "bugs": {
    "url": "https://github.com/mahdyarief/rindaman/issues"
  },
  "homepage": "https://github.com/mahdyarief/rindaman#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.8.2"
  },
  "pi": {
    "extensions": [
      "extensions/rindaman.ts"
    ],
    "skills": [
      "skills"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  }
}
