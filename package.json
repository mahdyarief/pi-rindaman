{
  "name": "pi-rindaman",
  "version": "1.0.0",
  "description": "Pi verification package and CLI for strict response discipline, lifecycle verification, and quality checks.",
  "type": "module",
  "bin": {
    "pi-rindaman": "bin/pi-rindaman.cjs"
  },
  "sideEffects": false,
  "files": [
    "bin",
    "extensions",
    "skills",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "src/cli",
    "src/quality-engine"
  ],
  "scripts": {
    "build": "node -e \"console.log('No build step required for Pi runtime-loaded extensions.')\"",
    "clean": "node -e \"console.log('Nothing to clean.')\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "format:check": "biome check .",
    "knip": "knip --reporter compact",
    "check": "node bin/pi-rindaman.cjs",
    "doctor": "node bin/pi-rindaman.cjs doctor",
    "release:check": "npm run typecheck && npm run build && npm run format:check && npm run knip && npm test && node bin/pi-rindaman.cjs doctor --json && node bin/pi-rindaman.cjs check --json --all && node bin/pi-rindaman.cjs audit --json --all && npm pack --dry-run --json",
    "release:pack": "npm pack",
    "test": "node --test"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "quality",
    "verification",
    "code-quality",
    "typescript",
    "biome",
    "knip"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mahdyarief/pi-rindaman.git"
  },
  "bugs": {
    "url": "https://github.com/mahdyarief/pi-rindaman/issues"
  },
  "homepage": "https://github.com/mahdyarief/pi-rindaman#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@sinclair/typebox": "^0.34.41",
    "@types/node": "^22.15.29",
    "knip": "^5.61.3",
    "typescript": "^5.8.2"
  },
  "pi": {
    "extensions": ["extensions/pi-rindaman.ts"],
    "skills": ["skills"]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  }
}
